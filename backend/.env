# Configurações do Banco de Dados
# Deixe vazio para usar SQLite (mais simples para desenvolvimento)
# Para PostgreSQL, descomente e configure as linhas abaixo:

# DATABASE_URL=postgresql://usuario:senha@localhost:5432/rivalis_db
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rivalis_db
# DB_USER=usuario
# DB_PASSWORD=senha

# Configurações JWT
JWT_SECRET=rivalis_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Configurações do Servidor
PORT=5001
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:5174