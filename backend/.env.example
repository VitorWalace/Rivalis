# Configurações do Banco de Dados

# Para Vercel Postgres (Produção) - será preenchido automaticamente
POSTGRES_URL=

# Para PostgreSQL local (Desenvolvimento)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/rivalis_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rivalis_db
DB_USER=usuario
DB_PASSWORD=senha

# Para SQLite (Desenvolvimento simples) - não precisa configurar nada

# Configurações JWT
JWT_SECRET=rivalis_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Configurações do Servidor
PORT=5000
NODE_ENV=development

# CORS - ajustar para sua URL de produção
FRONTEND_URL=http://localhost:5173